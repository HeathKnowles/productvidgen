# AI - Groq (Primary)
GROQ_API_KEY=gsk_...

# AI - OpenRouter (Fallback)
OPENROUTER_API_KEY=sk-or-...

# Assets - Pexels (Background Videos)
PEXELS_API_KEY=...

# Assets - Giphy (GIF Overlays)
GIPHY_API_KEY=...

# Audio - Apify (TikTok Sound Scraper)
APIFY_API_TOKEN=apify_api_...

# Audio - Freesound (SFX)
FREESOUND_API_KEY=...

# Storage - Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=ugc-videos

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
